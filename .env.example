# ============================================
# AI Workout Generator — environment variables
# ============================================
# Copy this file to .env.local and fill in ONE provider.
# Default provider is Gemini Flash (free tier).

# --- Gemini (default, FREE) -----------------
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional model override; defaults to gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash

# --- Provider selection (optional) ----------
# AI_PROVIDER=gemini   # or "anthropic" or "openai"

# --- Anthropic (optional fallback) ----------
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-7

# --- OpenAI (optional fallback) -------------
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# --- Resend (emails the PDF plan to the user) ---
# Get a free key at: https://resend.com/api-keys
RESEND_API_KEY=
# Sender address. onboarding@resend.dev works for testing but only delivers to
# your own Resend account email. Verify a domain to email arbitrary recipients.
# EMAIL_FROM=FitBudd <onboarding@resend.dev>
